# Server Config
NODE_ENV=production
PORT=5000

# Database
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/portfolio

# Security & CORS (Comma separated origins)
ALLOWED_ORIGINS=https://your-admin-site.vercel.app,https://your-portfolio-site.vercel.app

# JWT Secrets
JWT_SECRET=your_long_secure_jwt_secret
JWT_REFRESH_SECRET=your_long_secure_refresh_secret

# Email (SMTP)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
ADMIN_EMAIL=your_email@example.com

# Media (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
